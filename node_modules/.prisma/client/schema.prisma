generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id               String    @id @default(uuid())
  phone            String    @unique
  name             String?
  lastAddress      String?
  lastInteraction  DateTime  @default(now())
  lastFulfillment  String?
  preferredPayment String?
  handoff          Boolean   @default(false)
  handoffAt        DateTime?
  visitCount       Int       @default(0)
  lastOrderSummary String?
  preferences      String?
  lastLat          Float?
  lastLng          Float?
  lastStreet       String?
  lastNumber       String?
  lastNeighborhood String?
  lastComplement   String?
  orders           Order[]
}

model Order {
  id         String   @id @default(uuid())
  displayId  String   @unique
  cwOrderId  String?  @unique
  status     String   @default("waiting_confirmation")
  total      Float
  items      String
  cwJson     String?
  createdAt  DateTime @default(now())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Config {
  id    Int    @id @default(1)
  key   String @unique
  value String
}
