# =============================================
# BANCO DE DADOS (obrigatório)
# =============================================
# PostgreSQL - ex: Neon, Supabase, Railway, Render
DATABASE_URL="postgresql://usuario:senha@host:5432/nomebanco?sslmode=require"

# =============================================
# WHATSAPP CLOUD API (Meta)
# =============================================
WHATSAPP_TOKEN="seu_token_aqui"
WHATSAPP_PHONE_NUMBER_ID="seu_phone_number_id"
WHATSAPP_WABA_ID="seu_waba_id"
WEBHOOK_VERIFY_TOKEN="token_secreto_que_voce_escolhe"

# =============================================
# GEMINI (IA)
# =============================================
GEMINI_API_KEY="sua_chave_gemini"
GEMINI_MODEL="gemini-2.0-flash"

# =============================================
# CARDAPIO WEB (integração pedidos)
# =============================================
CARDAPIOWEB_BASE_URL="https://integracao.cardapioweb.com"
CARDAPIOWEB_API_KEY="sua_chave_da_loja"       # X-API-KEY
CARDAPIOWEB_PARTNER_KEY="chave_do_integrador" # X-PARTNER-KEY (peça ao suporte CardápioWeb)
CARDAPIOWEB_STORE_ID="id_da_sua_loja"

# =============================================
# GOOGLE MAPS (cálculo taxa entrega)
# =============================================
GOOGLE_MAPS_API_KEY="sua_chave_google_maps"

# =============================================
# BANCO INTER - PIX (opcional)
# =============================================
# INTER_CLIENT_ID="..."
# INTER_CLIENT_SECRET="..."
# INTER_CHAVE_PIX="19999999999"
# INTER_CONTA_CORRENTE="..."
# INTER_CERT_PATH="./certificados/inter.crt"
# INTER_KEY_PATH="./certificados/inter.key"

# =============================================
# LOJA (coordenadas para calcular raio de entrega)
# =============================================
# STORE_LAT=-22.9060
# STORE_LNG=-47.0616
